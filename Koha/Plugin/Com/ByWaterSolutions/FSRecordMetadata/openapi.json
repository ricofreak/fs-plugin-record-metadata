{
    "/entries": {
        "get": {
            "x-mojo-to": "Com::ByWaterSolutions::FSRecordMetadata::Controller#list_entries",
            "operationId": "fsrmListEntries",
            "tags": ["fsrecordmetadata"],
            "produces": ["application/json"],
            "parameters": [
                {
                    "name": "biblionumber",
                    "in": "query",
                    "description": "Filter by TN (biblionumber)",
                    "required": false,
                    "type": "integer"
                },
                {
                    "name": "barcode",
                    "in": "query",
                    "description": "Filter by barcode",
                    "required": false,
                    "type": "string"
                }
            ],
            "responses": {
                "200": {
                    "description": "A list of entries",
                    "schema": { "type": "array", "items": { "type": "object" } }
                },
                "400": {
                    "description": "Missing search parameter",
                    "schema": { "type": "object", "properties": { "error": { "type": "string" } } }
                },
                "500": {
                    "description": "Internal server error",
                    "schema": { "type": "object", "properties": { "error": { "type": "string" } } }
                }
            },
            "x-koha-authorization": {
                "permissions": { "catalogue": "1" }
            }
        }
    }
}
